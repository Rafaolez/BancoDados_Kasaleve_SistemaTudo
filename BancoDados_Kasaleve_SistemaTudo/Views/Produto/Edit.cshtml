@model BancoDados_Kasaleve_SistemaTudo.Models.Produto

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Produto</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="produtoId" />
            <div class="form-group">
                <label asp-for="produtoNome" class="control-label"></label>
                <input asp-for="produtoNome" class="form-control" />
                <span asp-validation-for="produtoNome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="produtoValor" class="control-label"></label>
                <input asp-for="produtoValor" class="form-control" />
                <span asp-validation-for="produtoValor" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="produtoFoto" class="control-label"></label>
                <input asp-for="produtoFoto" class="form-control" />
                <span asp-validation-for="produtoFoto" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TipoProdutoId" class="control-label"></label>
                <select asp-for="TipoProdutoId" class="form-control" asp-items="ViewBag.TipoProdutoId"></select>
                <span asp-validation-for="TipoProdutoId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
