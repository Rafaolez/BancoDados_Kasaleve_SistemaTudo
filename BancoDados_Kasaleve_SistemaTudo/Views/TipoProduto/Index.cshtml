@model IEnumerable<BancoDados_Kasaleve_SistemaTudo.Models.TipoProduto>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nome)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Produtos)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PrecosProdutos)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Nome)
            </td>
            <td>
                @Html.DisplayFor(model => item.Produtos)
            </td>
            <td>
                @Html.DisplayFor(model => item.PrecosProdutos)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.TipoProdutoId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.TipoProdutoId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.TipoProdutoId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
